    </div>
    <div class="check-row" style="margin-bottom:12px;">
      <input type="checkbox" id="gw-logging">
      <label for="gw-logging">开启脱敏请求日志（仅记录模型名改写 + 路径 + 时间，<b>绝不记录消息内容或密钥</b>，便于排查兼容问题）</label>
    </div>
    <button class="btn btn-primary" onclick="saveGateway()">&#x1f4be; 保存网关配置</button>
    <button class="btn btn-green" onclick="applyGatewayToClaudeDesktop()" style="margin-left:8px;">&#x26a1; 应用到 Claude Desktop</button>
    <div id="gw-status" style="font-size:12px;color:var(--text2);margin-top:12px;"></div>
  </div>
</section>
</main>

<div id="logpanel" style="position:fixed;bottom:0;left:0;right:0;background:#0a0a0a;border-top:1px solid var(--border);z-index:90;height:34px;overflow:hidden;transition:height .2s;">
  <div onclick="toggleLogPanel(event)" style="height:34px;display:flex;align-items:center;justify-content:space-between;padding:0 18px;cursor:pointer;user-select:none;font-size:12px;color:var(--text2);background:var(--bg2);">

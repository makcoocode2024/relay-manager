<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RelayManager — 中转站配置工具</title>
<style>
:root {
  --bg: #0f1117; --bg2: #1a1d27; --bg3: #242836; --border: #2e3348;
  --text: #e1e4eb; --text2: #9498a3; --accent: #6c8cff; --accent2: #4a6cf7;
  --green: #34d399; --red: #f87171; --yellow: #fbbf24; --radius: 8px;
  --shadow: 0 2px 12px rgba(0,0,0,.25);
  --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
}
body[data-theme="classic"] {
  --bg: #0f1117; --bg2: #1a1d27; --bg3: #242836; --border: #2e3348;
  --text: #e1e4eb; --text2: #9498a3; --accent: #6c8cff; --accent2: #4a6cf7; --radius: 8px;
}
body[data-theme="dashboard"] {
  --bg: #0d0d0d; --bg2: #1a1a1a; --bg3: #222222; --border: #2c2c2c;
  --text: #e8e8ea; --text2: #9a9aa2; --accent: #8b5cf6; --accent2: #7c3aed; --radius: 10px;
}
/* 现代精致深色：更柔和的层次、青色强调色、更圆润的圆角 */
body[data-theme="modern"] {
  --bg: #0b0f17; --bg2: #141a26; --bg3: #1d2533; --border: #2a3344;
  --text: #eef2f8; --text2: #8b95a7; --accent: #2dd4bf; --accent2: #14b8a6; --radius: 12px;
  --shadow: 0 4px 24px rgba(0,0,0,.35);
}
/* 清爽浅色：白底、柔和阴影、蓝色强调色，适合明亮环境 */
body[data-theme="light"] {
  --bg: #f4f6fb; --bg2: #ffffff; --bg3: #eef1f7; --border: #dfe4ec;
  --text: #1f2733; --text2: #647084; --accent: #3b6cf6; --accent2: #2554e0; --radius: 12px;
  --shadow: 0 2px 12px rgba(31,39,51,.08);
}
* { margin:0; padding:0; box-sizing:border-box; }
body { background:var(--bg); color:var(--text); font-family:var(--font); min-height:100vh; transition:background .25s ease, color .25s ease; }
body[data-sidebar-layout="compact"] .tabs { gap:2px; }
body[data-sidebar-layout="compact"] .tab { padding:4px 10px; font-size:12px; }
body[data-sidebar-layout="compact"] main { max-width:1120px; }
body[data-sidebar-layout="compact"] .card { padding:16px; }

/* ===== 侧边栏导航布局：顶部横向标签 → 左侧竖向侧边栏 ===== */
body[data-sidebar-layout="sidebar"] {
  display:grid;
  grid-template-columns: 240px 1fr;
  min-height:100vh;
}
body[data-sidebar-layout="sidebar"] header {
  position:sticky; top:0; height:100vh; width:240px; flex-direction:column;
  align-items:stretch; gap:10px; padding:18px 14px; border-bottom:none;
  border-right:1px solid var(--border); overflow-y:auto; z-index:100;
}
body[data-sidebar-layout="sidebar"] header h1 { font-size:17px; margin-bottom:6px; padding:0 6px; }
body[data-sidebar-layout="sidebar"] .tabs { flex-direction:column; gap:3px; flex-wrap:nowrap; }
body[data-sidebar-layout="sidebar"] .tab { width:100%; text-align:left; padding:10px 12px; }
body[data-sidebar-layout="sidebar"] header > div[style*="margin-left:auto"] { margin-left:0 !important; }
body[data-sidebar-layout="sidebar"] header > div[id="proc-indicator"] { width:100%; justify-content:flex-start; }
body[data-sidebar-layout="sidebar"] main { margin:0; max-width:1120px; width:100%; }
body[data-sidebar-layout="sidebar"] #logpanel { left:240px; }
@media (max-width:860px){
  body[data-sidebar-layout="sidebar"] { grid-template-columns: 1fr; }
  body[data-sidebar-layout="sidebar"] header { position:static; width:auto; height:auto; border-right:none; border-bottom:1px solid var(--border); }
  body[data-sidebar-layout="sidebar"] .tabs { flex-direction:row; flex-wrap:wrap; }
  body[data-sidebar-layout="sidebar"] main { margin-left:auto; }
  body[data-sidebar-layout="sidebar"] #logpanel { left:0; }
}

header {
  background:var(--bg2); border-bottom:1px solid var(--border);
  padding:12px 24px; display:flex; align-items:center; gap:12px; flex-wrap:wrap;
  position:sticky; top:0; z-index:100; backdrop-filter:blur(12px);
  box-shadow:var(--shadow);
}
header h1 { font-size:18px; font-weight:600; color:var(--accent); white-space:nowrap; }
.tabs { display:flex; gap:4px; flex-wrap:wrap; }
.tab {
  padding:6px 14px; border-radius:6px; cursor:pointer;
  font-size:13px; color:var(--text2); border:1px solid transparent;
  transition:all .15s; white-space:nowrap; user-select:none;
}
.tab:hover { color:var(--text); background:var(--bg3); }
.tab.active { color:var(--accent); background:var(--bg3); border-color:var(--accent); }
main { max-width:960px; margin:0 auto; padding:24px 16px 80px; }
#logpanel.open { height:300px; }
.log-line { padding:3px 6px;border-radius:4px;white-space:nowrap;color:var(--text2); }
.log-line:hover { background:var(--bg3); }
.log-line .st-ok { color:var(--green); } .log-line .st-err { color:var(--red); } .log-line .st-warn { color:var(--yellow); }
.hist-item { display:flex;justify-content:space-between;align-items:center;padding:10px 12px;border:1px solid var(--border);border-radius:8px;margin-bottom:8px;font-size:12.5px; }
.hist-item .meta { color:var(--text2);font-size:11px; }
#proc-indicator:hover { background:var(--bg3); }
#proc-dot.on { background:var(--green)!important;box-shadow:0 0 8px var(--green); }
.tab-panel { display:none; }
.tab-panel.active { display:block; }

.card { background:var(--bg2); border:1px solid var(--border); border-radius:var(--radius); padding:20px; margin-bottom:20px; box-shadow:var(--shadow); transition:border-color .15s, box-shadow .15s; }
.card:hover { border-color:var(--accent); }
.card h2 { font-size:15px; font-weight:600; margin-bottom:16px; color:var(--text); }
.card h3 { font-size:13px; font-weight:600; color:var(--text2); margin-bottom:8px; }

.form-group { margin-bottom:14px; }
.form-group label { display:block; font-size:12px; color:var(--text2); margin-bottom:4px; font-weight:500; }
.form-group input, .form-group select, .form-group textarea {
  width:100%; padding:8px 12px; background:var(--bg3); border:1px solid var(--border);
  border-radius:6px; color:var(--text); font-size:13px; font-family:var(--font);
  outline:none; transition:border-color .15s;
}
.form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color:var(--accent); }
.form-group textarea { min-height:80px; resize:vertical; }
.form-row { display:flex; gap:12px; }
.form-row .form-group { flex:1; }

.pwd-wrap { position:relative; }
.pwd-wrap input { padding-right:42px; }
.pwd-toggle { position:absolute; right:8px; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--text2); cursor:pointer; font-size:13px; padding:4px; }
.pwd-toggle:hover { color:var(--text); }

.btn {
  padding:8px 18px; border-radius:6px; font-size:13px; font-weight:500; cursor:pointer;
  border:1px solid transparent; transition:all .15s; font-family:var(--font);
  display:inline-flex; align-items:center; gap:6px;
}
.btn:active { transform:translateY(1px); }
.btn-primary { background:var(--accent); color:#fff; border-color:var(--accent); }
.btn-primary:hover { background:var(--accent2); box-shadow:0 2px 10px color-mix(in srgb, var(--accent) 45%, transparent); }
.btn-green { background:var(--green); color:#000; }
.btn-green:hover { opacity:.85; }
.btn-red { background:transparent; color:var(--red); border-color:var(--red); }
.btn-red:hover { background:var(--red); color:#fff; }
.btn-yellow { background:var(--yellow); color:#000; }
.btn-yellow:hover { opacity:.85; }
.btn-outline { background:transparent; border-color:var(--border); color:var(--text); }
.btn-outline:hover { background:var(--bg3); }
.btn-sm { padding:5px 12px; font-size:12px; }
.btn-lg { padding:12px 28px; font-size:15px; }

.sync-section { text-align:center; padding:28px; }
.sync-section h2 { font-size:20px; margin-bottom:20px; }
.sync-fields { max-width:480px; margin:0 auto 20px; }
.sync-checks { display:flex; gap:16px; justify-content:center; margin-bottom:16px; flex-wrap:wrap; }
.sync-checks label { display:flex; align-items:center; gap:4px; font-size:12px; color:var(--text2); cursor:pointer; }
.sync-checks input[type=checkbox] { accent-color:var(--accent); }

.status-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:12px; }
.status-card { background:var(--bg3); border-radius:var(--radius); padding:14px; border:1px solid var(--border); }
.status-card .name { font-size:12px; color:var(--text2); margin-bottom:6px; }
.status-card .url { font-size:11px; color:var(--accent); word-break:break-all; margin-bottom:4px; }
.status-card .key { font-size:11px; color:var(--text2); word-break:break-all; }
.status-dot { display:inline-block; width:8px; height:8px; border-radius:50%; margin-right:6px; }
.status-dot.set { background:var(--green); }
.status-dot.unset { background:var(--red); }

.proxy-status { display:flex; align-items:center; gap:12px; padding:12px 16px; background:var(--bg3); border-radius:var(--radius); margin-bottom:16px; }
.proxy-status .indicator { width:10px; height:10px; border-radius:50%; }
.proxy-status .indicator.on { background:var(--green); box-shadow:0 0 8px var(--green); }
.proxy-status .indicator.off { background:var(--red); }
.proxy-status .info { font-size:13px; }

.upstream-table { width:100%; border-collapse:collapse; font-size:12px; margin-top:8px; }
.upstream-table th { text-align:left; padding:8px; color:var(--text2); border-bottom:1px solid var(--border); font-weight:500; }
.upstream-table td { padding:8px; border-bottom:1px solid var(--border); vertical-align:top; }
.upstream-table td input { background:var(--bg3); border:1px solid var(--border); color:var(--text); padding:4px 8px; border-radius:4px; font-size:11px; width:100%; }
.upstream-table td select { background:var(--bg3); border:1px solid var(--border); color:var(--text); padding:4px 8px; border-radius:4px; font-size:11px; }
.upstream-table .mono { font-family:monospace; font-size:10px; color:var(--accent); word-break:break-all; }

.toast-container { position:fixed; top:16px; right:16px; z-index:999; display:flex; flex-direction:column; gap:8px; }
.toast { padding:12px 20px; border-radius:var(--radius); font-size:13px; animation:slideIn .25s ease; max-width:380px; }
.toast.success { background:#065f46; color:#a7f3d0; border:1px solid #059669; }
.toast.error { background:#7f1d1d; color:#fecaca; border:1px solid #dc2626; }
@keyframes slideIn { from { transform:translateX(100%);opacity:0; } to { transform:translateX(0);opacity:1; } }

.loading { display:inline-block; width:16px; height:16px; border:2px solid var(--border); border-top-color:var(--accent); border-radius:50%; animation:spin .6s linear infinite; }
@keyframes spin { to { transform:rotate(360deg); } }

.check-row { display:flex; align-items:center; gap:8px; }
.check-row input[type=checkbox] { width:auto; accent-color:var(--accent); }

.tag { display:inline-block; padding:2px 8px; border-radius:4px; font-size:11px; background:var(--bg3); color:var(--text2); }
.tag.active { background:#065f46; color:#a7f3d0; }
.tag.suspended { background:#7f1d1d; color:#fecaca; }

.model-list { max-height:300px; overflow-y:auto; margin-top:8px; }
.model-item { display:flex; align-items:center; justify-content:space-between; padding:6px 10px; border-radius:4px; margin-bottom:2px; background:var(--bg3); font-size:12px; }
.model-item:hover { background:var(--bg); }
.model-item .model-id { font-family:monospace; color:var(--accent); font-size:11px; flex:1; }
.model-item .model-owner { color:var(--text2); font-size:10px; margin:0 12px; }
.model-item .copy-btn { cursor:pointer; color:var(--accent); font-size:11px; border:none; background:none; padding:2px 6px; }
.model-item .copy-btn:hover { color:var(--text); }

.mapping-row { display:flex; gap:8px; align-items:center; margin-bottom:8px; }
.mapping-row input { flex:1; }
.mapping-row span { color:var(--text2); font-size:12px; min-width:20px; text-align:center; }
</style>
</head>
<body data-theme="classic">

<header>
  <h1>⚡ RelayManager</h1>
  <nav class="tabs" id="tabs">
    <div class="tab active" data-tab="overview">&#x1f4ca; 总览</div>
    <div class="tab" data-tab="claude-code">Claude Code</div>
    <div class="tab" data-tab="claude-desktop">Claude Desktop</div>
    <div class="tab" data-tab="codex-cli">Codex CLI</div>
    <div class="tab" data-tab="codex-desktop">Codex Desktop</div>
    <div class="tab" data-tab="models">&#x1f4e6; 模型映射</div>
    <div class="tab" data-tab="gateway">&#x1f6e3; 中转网关</div>
  </nav>
  <div style="margin-left:auto;display:flex;align-items:center;gap:7px;">
    <span style="font-size:11px;color:var(--text2);">主题</span>
    <select id="theme-select" onchange="setTheme(this.value)" style="font-size:12px;padding:6px 8px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;color:var(--text);cursor:pointer;">
      <option value="classic">经典蓝</option>
      <option value="dashboard">深色仪表板</option>
      <option value="modern">现代精致深色</option>
      <option value="light">清爽浅色</option>
    </select>
  </div>
  <div style="display:flex;align-items:center;gap:7px;">
    <span style="font-size:11px;color:var(--text2);">边栏</span>
    <select id="sidebar-layout-select" onchange="setSidebarLayout(this.value)" style="font-size:12px;padding:6px 8px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;color:var(--text);cursor:pointer;">
      <option value="classic">经典侧栏</option>
      <option value="compact">紧凑侧栏</option>
      <option value="sidebar">侧边栏导航</option>
    </select>
  </div>
  <div id="proc-indicator" onclick="restartProcessQuick()" title="Claude Desktop 进程状态 — 点击重启" style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:12px;color:var(--text2);padding:6px 12px;border-radius:8px;border:1px solid var(--border);white-space:nowrap;">
    <span id="proc-dot" style="width:9px;height:9px;border-radius:50%;background:#555;display:inline-block;"></span>
    <span id="proc-text">检查中…</span>
  </div>
</header>

<main>
<!-- ============ OVERVIEW TAB ============ -->
<section class="tab-panel active" id="panel-overview">
  <div class="card sync-section">
    <h2>&#x1f504; 一键同步所有产品</h2>
    <p style="color:var(--text2);font-size:13px;margin-bottom:16px;">设置相同的 Base URL 和 API Key 到所有产品</p>
    <div class="sync-fields">
      <div class="form-group">
        <label>Base URL</label>
        <input type="text" id="sync-base-url" placeholder="https://api.example.com/v1">
      </div>
      <div class="form-group">
        <label>API Key</label>
        <div class="pwd-wrap">
          <input type="password" id="sync-api-key" placeholder="sk-...">
          <button class="pwd-toggle" onclick="togglePwd('sync-api-key',this)">&#x1f441;</button>
        </div>
      </div>
    </div>
    <div class="sync-checks">
      <label><input type="checkbox" checked id="sync-cc"> Claude Code</label>
      <label><input type="checkbox" checked id="sync-cd"> Claude Desktop</label>
      <label><input type="checkbox" checked id="sync-cx"> Codex CLI</label>
      <label><input type="checkbox" checked id="sync-cxd"> Codex Desktop</label>
    </div>
    <button class="btn btn-primary btn-lg" onclick="doSyncAll()">&#x26a1; 应用到所有产品</button>
  </div>

  <div class="card">
    <h2>&#x1f4ca; 当前配置状态</h2>
    <div class="status-grid" id="status-grid">加载中...</div>
  </div>

  <!-- Relay Connectivity Test Card -->
  <div class="card">
    <h2>&#x1f50d; 中转站连通性检测</h2>
    <p style="font-size:12px;color:var(--text2);margin-bottom:12px;">输入任意中转站的 Base URL 和 API Key，测试连接是否可用，或获取可用模型列表。</p>
    <div class="form-row">
      <div class="form-group">
        <label>Base URL</label>
        <input type="text" id="test-base-url" placeholder="https://api.example.com">
      </div>
      <div class="form-group">
        <label>API Key</label>
        <div class="pwd-wrap">
          <input type="password" id="test-api-key" placeholder="sk-...">
          <button class="pwd-toggle" onclick="togglePwd('test-api-key',this)">&#x1f441;</button>
        </div>
      </div>
    </div>
    <div class="form-row" style="margin-top:4px;align-items:flex-end;">
      <div class="form-group">
        <label>应用到产品</label>
        <div id="test-apply-target" style="display:flex;flex-direction:column;gap:8px;padding:10px 12px;border:1px solid var(--border);border-radius:8px;background:var(--bg2);max-height:180px;overflow:auto;">
          <label class="check-row" style="margin:0;"><input type="checkbox" value="claude-code" checked><span>Claude Code</span></label>
          <label class="check-row" style="margin:0;"><input type="checkbox" value="claude-desktop" checked><span>Claude Desktop</span></label>
          <label class="check-row" style="margin:0;"><input type="checkbox" value="codex-cli" checked><span>Codex CLI</span></label>
          <label class="check-row" style="margin:0;"><input type="checkbox" value="codex-desktop" checked><span>Codex Desktop</span></label>
        </div>
      </div>
      <div class="form-group" style="justify-content:flex-end;">
        <label class="check-row" style="margin:0 0 8px;">
          <input type="checkbox" id="test-apply-restart">
          <span>应用后自动重启相关客户端</span>
        </label>
        <button class="btn btn-primary btn-sm" onclick="applyRelayToSelectedProducts()">&#x1f4be; 应用到所选产品并保存</button>
        <div style="font-size:11px;color:var(--text2);margin-top:8px;">会先回填当前检测到的 Base URL / API Key，再调用各产品现有保存逻辑。</div>
      </div>
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
      <button class="btn btn-outline btn-sm" onclick="testRelayConnection()">&#x1f50c; 测试连接</button>
      <button class="btn btn-outline btn-sm" onclick="testRelayFetchModels()">&#x1f4e6; 获取模型列表</button>
      <span id="test-status" style="font-size:12px;color:var(--text2);"></span>
    </div>
    <div class="model-list" id="test-models-list" style="margin-top:12px;"></div>
  </div>

  <!-- Proxy Control Card -->
  <div class="card">
    <h2>&#x1f310; 代理控制 (Clash Verge)</h2>
    <div class="proxy-status" id="proxy-status-overview">检查中...</div>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
      <button class="btn btn-green btn-sm" onclick="proxyStart()">&#x25b6; 启动代理</button>
      <button class="btn btn-red btn-sm" onclick="proxyStop()">&#x25a0; 停止代理</button>
      <button class="btn btn-yellow btn-sm" onclick="restartApp('proxy')">&#x21bb; 重启代理</button>
      <button class="btn btn-outline btn-sm" onclick="proxyRefreshStatus()">&#x21bb; 刷新状态</button>
    </div>
  </div>

  <!-- App Restart Card -->
  <div class="card">
    <h2>&#x1f504; 重启客户端</h2>
    <p style="font-size:12px;color:var(--text2);margin-bottom:12px;">配置修改后需要重启客户端才能生效</p>
    <div style="display:flex;gap:8px;flex-wrap:wrap;" id="restart-buttons">
      <button class="btn btn-yellow btn-sm" onclick="restartApp('claude-desktop')">&#x21bb; 重启 Claude Desktop</button>
      <button class="btn btn-yellow btn-sm" onclick="restartApp('codex-desktop')">&#x21bb; 重启 Codex Desktop</button>
      <button class="btn btn-yellow btn-sm" onclick="restartApp('proxy')">&#x21bb; 重启 Clash Verge</button>
    </div>
    <div id="restart-status" style="font-size:11px;color:var(--text2);margin-top:8px;"></div>
  </div>

  <!-- App Paths Config Card -->
  <div class="card">
    <h2>&#x1f4c2; 应用路径设置</h2>
    <p style="font-size:12px;color:var(--text2);margin-bottom:12px;">重启功能需要知道各应用的 exe 路径。未自动检测到的（如 Claude Desktop）请手动填写。右键应用快捷方式 → 属性 → 复制「目标」里的路径。</p>
    <div class="form-group">
      <label>Claude Desktop exe 路径 <span id="path-status-claude-desktop" style="font-size:11px;"></span></label>
      <input type="text" id="path-claude-desktop" placeholder="C:\Users\admin\AppData\Local\Claude-3p\Claude.exe">
    </div>
    <div class="form-group">
      <label>Codex Desktop exe 路径 <span id="path-status-codex-desktop" style="font-size:11px;"></span></label>
      <input type="text" id="path-codex-desktop" placeholder="G:\Program Files\CCX\CCX Desktop\ccx-desktop.exe">
    </div>
    <div class="form-group">
      <label>Clash Verge exe 路径 <span id="path-status-proxy" style="font-size:11px;"></span></label>
      <input type="text" id="path-proxy" placeholder="C:\Program Files\Clash Verge\Clash Verge.exe">
    </div>
    <button class="btn btn-primary btn-sm" onclick="saveAppPaths()">&#x1f4be; 保存路径</button>
  </div>

  <!-- Auto-start Card -->
  <div class="card">
    <h2>&#x1f50a; 开机自启</h2>
